{
  "name": "zip-analyzer-tool",
  "version": "1.0.0",
  "description": "ZIP 파일 분석 및 편집 도구 - Cloudflare Workers 배포",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
