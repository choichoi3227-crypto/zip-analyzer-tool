    "form-data": "^4.0.0",
    "jszip": "^3.10.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "wrangler": "^3.26.0",
    "@cloudflare/workers-types": "^4.20231121.0",
    "typescript": "^5.3.3",
    "esbuild": "^0.19.8",
    "@types/node": "^20.10.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.10",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "cloudflare-workers",
    "zip-analysis",
